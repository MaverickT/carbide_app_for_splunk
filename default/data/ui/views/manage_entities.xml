<form version="1.1" theme="dark" script="carbide_inline_edit.js" stylesheet="carbide.css" hideEdit="false">
    <label>Manage entities</label>
    <description>Tracked hosts and sources in one place. Toggle between Hosts and Sources at the top. Click any blue cell to edit; quick-action buttons act on every row matching the current filter.</description>

    <fieldset submitButton="false" autoRun="true">
        <input type="dropdown" token="type_tok" searchWhenChanged="true">
            <label>I want to manage</label>
            <choice value="host">Hosts</choice>
            <choice value="source">Sources</choice>
            <default>host</default>
            <change>
                <condition value="host"><set token="is_host">1</set><unset token="is_source"/></condition>
                <condition value="source"><set token="is_source">1</set><unset token="is_host"/></condition>
            </change>
        </input>
        <input type="dropdown" token="monitored_tok" searchWhenChanged="true">
            <label>Watching</label>
            <choice value="*">All</choice>
            <choice value="1">On (watching)</choice>
            <choice value="0">Off (not watching)</choice>
            <default>*</default>
        </input>
        <input type="dropdown" token="status_tok" searchWhenChanged="true">
            <label>Status</label>
            <choice value=".*">All</choice>
            <choice value="OK">Healthy</choice>
            <choice value="LATE">Delayed</choice>
            <choice value="DOWN|CRITICAL">Missing (DOWN / CRITICAL)</choice>
            <choice value="MAINT">Snoozed</choice>
            <choice value="OFF_HOURS">Off-hours</choice>
            <choice value="NEW">Just added</choice>
            <default>.*</default>
        </input>
        <input type="text" token="search_tok" searchWhenChanged="true">
            <label>Search</label>
            <default>.*</default>
        </input>
        <input type="text" token="tag_tok" searchWhenChanged="true">
            <label>Tag</label>
            <default>.*</default>
        </input>
        <input type="dropdown" token="show_details" searchWhenChanged="true">
            <label>Show details</label>
            <choice value="0">No</choice>
            <choice value="1">Yes</choice>
            <default>0</default>
        </input>
    </fieldset>

    <row>
        <panel>
            <html>
                <div class="carbide-quick" depends="$is_host$">
                    <strong>Quick actions on filtered rows</strong>
                    <button class="carbide-quick-btn"
                            data-carbide-target="carbide_tracked_hosts_table"
                            data-carbide-collection="carbide_tracked_hosts"
                            data-carbide-field="monitored"
                            data-carbide-value="1"
                            data-carbide-confirm="Start watching {n} rows?">Start watching</button>
                    <button class="carbide-quick-btn carbide-quick-danger"
                            data-carbide-target="carbide_tracked_hosts_table"
                            data-carbide-collection="carbide_tracked_hosts"
                            data-carbide-field="monitored"
                            data-carbide-value="0"
                            data-carbide-confirm="Stop watching {n} rows?">Stop watching</button>
                    <span class="carbide-quick-divider"/>
                    <button class="carbide-quick-btn"
                            data-carbide-target="carbide_tracked_hosts_table"
                            data-carbide-collection="carbide_tracked_hosts"
                            data-carbide-field="maintenance_until"
                            data-carbide-duration="+1h"
                            data-carbide-confirm="Snooze {n} rows for 1 hour?">🔧 Snooze 1h</button>
                    <button class="carbide-quick-btn"
                            data-carbide-target="carbide_tracked_hosts_table"
                            data-carbide-collection="carbide_tracked_hosts"
                            data-carbide-field="maintenance_until"
                            data-carbide-duration="+1d"
                            data-carbide-confirm="Snooze {n} rows for 1 day?">🔧 Snooze 1d</button>
                    <button class="carbide-quick-btn"
                            data-carbide-target="carbide_tracked_hosts_table"
                            data-carbide-collection="carbide_tracked_hosts"
                            data-carbide-field="maintenance_until"
                            data-carbide-duration="off"
                            data-carbide-confirm="End snooze on {n} rows?">End snooze</button>
                    <span class="carbide-quick-divider"/>
                    <button class="carbide-quick-btn"
                            data-carbide-target="carbide_tracked_hosts_table"
                            data-carbide-collection="carbide_tracked_hosts"
                            data-carbide-field="monitoring_schedule"
                            data-carbide-value="247"
                            data-carbide-confirm="Set schedule = 24/7 on {n} rows?">📅 24/7</button>
                    <button class="carbide-quick-btn"
                            data-carbide-target="carbide_tracked_hosts_table"
                            data-carbide-collection="carbide_tracked_hosts"
                            data-carbide-field="monitoring_schedule"
                            data-carbide-value="weekdays"
                            data-carbide-confirm="Set schedule = weekdays on {n} rows?">📅 Weekdays</button>
                    <button class="carbide-quick-btn"
                            data-carbide-target="carbide_tracked_hosts_table"
                            data-carbide-collection="carbide_tracked_hosts"
                            data-carbide-field="monitoring_schedule"
                            data-carbide-value="business_hours"
                            data-carbide-confirm="Set schedule = business hours on {n} rows?">📅 Business hrs</button>
                </div>
                <div class="carbide-quick" depends="$is_source$">
                    <strong>Quick actions on filtered rows</strong>
                    <button class="carbide-quick-btn"
                            data-carbide-target="carbide_tracked_sources_table"
                            data-carbide-collection="carbide_tracked_sources"
                            data-carbide-field="monitored"
                            data-carbide-value="1"
                            data-carbide-confirm="Start watching {n} rows?">Start watching</button>
                    <button class="carbide-quick-btn carbide-quick-danger"
                            data-carbide-target="carbide_tracked_sources_table"
                            data-carbide-collection="carbide_tracked_sources"
                            data-carbide-field="monitored"
                            data-carbide-value="0"
                            data-carbide-confirm="Stop watching {n} rows?">Stop watching</button>
                    <span class="carbide-quick-divider"/>
                    <button class="carbide-quick-btn"
                            data-carbide-target="carbide_tracked_sources_table"
                            data-carbide-collection="carbide_tracked_sources"
                            data-carbide-field="maintenance_until"
                            data-carbide-duration="+1h"
                            data-carbide-confirm="Snooze {n} rows for 1 hour?">🔧 Snooze 1h</button>
                    <button class="carbide-quick-btn"
                            data-carbide-target="carbide_tracked_sources_table"
                            data-carbide-collection="carbide_tracked_sources"
                            data-carbide-field="maintenance_until"
                            data-carbide-duration="+1d"
                            data-carbide-confirm="Snooze {n} rows for 1 day?">🔧 Snooze 1d</button>
                    <button class="carbide-quick-btn"
                            data-carbide-target="carbide_tracked_sources_table"
                            data-carbide-collection="carbide_tracked_sources"
                            data-carbide-field="maintenance_until"
                            data-carbide-duration="off"
                            data-carbide-confirm="End snooze on {n} rows?">End snooze</button>
                    <span class="carbide-quick-divider"/>
                    <button class="carbide-quick-btn"
                            data-carbide-target="carbide_tracked_sources_table"
                            data-carbide-collection="carbide_tracked_sources"
                            data-carbide-field="monitoring_schedule"
                            data-carbide-value="247"
                            data-carbide-confirm="Set schedule = 24/7 on {n} rows?">📅 24/7</button>
                    <button class="carbide-quick-btn"
                            data-carbide-target="carbide_tracked_sources_table"
                            data-carbide-collection="carbide_tracked_sources"
                            data-carbide-field="monitoring_schedule"
                            data-carbide-value="weekdays"
                            data-carbide-confirm="Set schedule = weekdays on {n} rows?">📅 Weekdays</button>
                    <button class="carbide-quick-btn"
                            data-carbide-target="carbide_tracked_sources_table"
                            data-carbide-collection="carbide_tracked_sources"
                            data-carbide-field="monitoring_schedule"
                            data-carbide-value="business_hours"
                            data-carbide-confirm="Set schedule = business hours on {n} rows?">📅 Business hrs</button>
                </div>
            </html>
        </panel>
    </row>

    <row depends="$is_host$">
        <panel>
            <title>Tracked hosts</title>
            <table id="carbide_tracked_hosts_table"
                   data-carbide-collection="carbide_tracked_hosts"
                   data-carbide-editable="monitored,max_gap_seconds,max_latency_seconds,notes,maintenance_from,maintenance_until,monitoring_schedule,tags,tracking_mode"
                   data-carbide-numeric="max_gap_seconds,max_latency_seconds,monitored,maintenance_from,maintenance_until"
                   data-carbide-min-max_gap_seconds="0"
                   data-carbide-min-max_latency_seconds="0"
                   data-carbide-options-monitored="0,1"
                   data-carbide-options-tracking_mode="index_host,host_source,host_sourcetype"
                   data-carbide-options-monitoring_schedule="247,weekdays,business_hours"
                   data-carbide-duration-fields="maintenance_from,maintenance_until"
                   data-carbide-label-monitored="Watching"
                   data-carbide-label-max_gap_seconds="Alert if quiet for (sec)"
                   data-carbide-label-max_latency_seconds="Alert if delayed by (sec)"
                   data-carbide-label-maintenance_from="Snooze from"
                   data-carbide-label-maintenance_until="Snooze until"
                   data-carbide-label-monitoring_schedule="Schedule"
                   data-carbide-label-tracking_mode="Grouped by"
                   data-carbide-label-tags="Tags"
                   data-carbide-label-entity_key="Entity"
                   data-carbide-detail-cols="_key,entity_key,tracking_mode,notes,first seen,last updated">
                <search>
                    <progress>
                        <condition match="'job.resultCount' == 0">
                            <set token="show_empty_h">1</set>
                        </condition>
                        <condition>
                            <unset token="show_empty_h"/>
                        </condition>
                    </progress>
                    <query>
                        | inputlookup carbide_tracked_hosts_lookup
                        | where match(coalesce(entity_key,"")."|".coalesce(index,"")."|".coalesce(host,"")."|".coalesce(source,"")."|".coalesce(sourcetype,"")."|".coalesce(notes,""), "$search_tok$")
                        | where match(coalesce(tags,""), "$tag_tok$")
                        | search monitored="$monitored_tok$"
                        | eval status        = coalesce(last_status, "NEW")
                        | where match(status, "^($status_tok$)$")
                        | `carbide_friendly_status`
                        | eval first_seen_h   = if(isnull(first_seen),  "-", strftime(first_seen,  "%Y-%m-%d %H:%M:%S"))
                        | eval last_updated_h = if(isnull(last_updated),"-", strftime(last_updated,"%Y-%m-%d %H:%M:%S"))
                        | eval last_event_h   = if(isnull(last_event_time) OR last_event_time=0, "-", strftime(last_event_time,"%Y-%m-%d %H:%M:%S"))
                        | `carbide_humanize_until(maintenance_from)`
                        | `carbide_humanize_until(maintenance_until)`
                        | eval tags                = coalesce(tags, "")
                        | eval monitoring_schedule = coalesce(monitoring_schedule, "247")
                        | sort + entity_key
                        | table _key, status_h, monitored, entity_key, monitoring_schedule, tags,
                                max_gap_seconds, max_latency_seconds,
                                maintenance_from, maintenance_from_h, maintenance_until, maintenance_until_h,
                                last_event_h, tracking_mode, first_seen_h, last_updated_h, notes
                        | rename
                            status_h as "status",
                            entity_key as "entity",
                            maintenance_from_h as "snooze from",
                            maintenance_until_h as "snooze until",
                            last_event_h as "last event",
                            tracking_mode as "grouped by",
                            first_seen_h as "first seen",
                            last_updated_h as "last updated"
                    </query>
                    </search>
                <option name="drilldown">none</option>
                <option name="count">50</option>
                <option name="wrap">false</option>
                <option name="refresh.display">progressbar</option>
                <format type="color" field="status">
                    <colorPalette type="map">{"✓ Healthy":#53a051,"⚠ Delayed":#f8be34,"✗ Missing data":#dc4e41,"✗ Missing + delayed":#9b1d1d,"🔧 Snoozed":#4ea1f2,"🌙 Off-hours":#6c63ff,"· Just added":#888888,"-":#888888}</colorPalette>
                </format>
            </table>
        </panel>
    </row>

    <row depends="$is_host$ AND $show_empty_h$">
        <panel>
            <html>
                <div class="carbide-empty-state">
                    <h3>No host entities match the current filter</h3>
                    <p>If you've just installed Carbide, run discovery first: <em>Carbide - Discover hosts (recommended)</em> from Settings &#8250; Searches.</p>
                </div>
            </html>
        </panel>
    </row>

    <row depends="$is_source$">
        <panel>
            <title>Tracked sources</title>
            <table id="carbide_tracked_sources_table"
                   data-carbide-collection="carbide_tracked_sources"
                   data-carbide-editable="monitored,max_gap_seconds,max_latency_seconds,notes,maintenance_from,maintenance_until,monitoring_schedule,tags,tracking_mode"
                   data-carbide-numeric="max_gap_seconds,max_latency_seconds,monitored,maintenance_from,maintenance_until"
                   data-carbide-min-max_gap_seconds="0"
                   data-carbide-min-max_latency_seconds="0"
                   data-carbide-options-monitored="0,1"
                   data-carbide-options-tracking_mode="index_source,index_sourcetype"
                   data-carbide-options-monitoring_schedule="247,weekdays,business_hours"
                   data-carbide-duration-fields="maintenance_from,maintenance_until"
                   data-carbide-label-monitored="Watching"
                   data-carbide-label-max_gap_seconds="Alert if quiet for (sec)"
                   data-carbide-label-max_latency_seconds="Alert if delayed by (sec)"
                   data-carbide-label-maintenance_from="Snooze from"
                   data-carbide-label-maintenance_until="Snooze until"
                   data-carbide-label-monitoring_schedule="Schedule"
                   data-carbide-label-tracking_mode="Grouped by"
                   data-carbide-label-tags="Tags"
                   data-carbide-label-entity_key="Entity"
                   data-carbide-detail-cols="_key,entity_key,tracking_mode,notes,first seen,last updated">
                <search>
                    <progress>
                        <condition match="'job.resultCount' == 0">
                            <set token="show_empty_s">1</set>
                        </condition>
                        <condition>
                            <unset token="show_empty_s"/>
                        </condition>
                    </progress>
                    <query>
                        | inputlookup carbide_tracked_sources_lookup
                        | where match(coalesce(entity_key,"")."|".coalesce(index,"")."|".coalesce(source,"")."|".coalesce(sourcetype,"")."|".coalesce(notes,""), "$search_tok$")
                        | where match(coalesce(tags,""), "$tag_tok$")
                        | search monitored="$monitored_tok$"
                        | eval status        = coalesce(last_status, "NEW")
                        | where match(status, "^($status_tok$)$")
                        | `carbide_friendly_status`
                        | eval first_seen_h   = if(isnull(first_seen),  "-", strftime(first_seen,  "%Y-%m-%d %H:%M:%S"))
                        | eval last_updated_h = if(isnull(last_updated),"-", strftime(last_updated,"%Y-%m-%d %H:%M:%S"))
                        | eval last_event_h   = if(isnull(last_event_time) OR last_event_time=0, "-", strftime(last_event_time,"%Y-%m-%d %H:%M:%S"))
                        | `carbide_humanize_until(maintenance_from)`
                        | `carbide_humanize_until(maintenance_until)`
                        | eval tags                = coalesce(tags, "")
                        | eval monitoring_schedule = coalesce(monitoring_schedule, "247")
                        | sort + entity_key
                        | table _key, status_h, monitored, entity_key, monitoring_schedule, tags,
                                max_gap_seconds, max_latency_seconds,
                                maintenance_from, maintenance_from_h, maintenance_until, maintenance_until_h,
                                last_event_h, tracking_mode, first_seen_h, last_updated_h, notes
                        | rename
                            status_h as "status",
                            entity_key as "entity",
                            maintenance_from_h as "snooze from",
                            maintenance_until_h as "snooze until",
                            last_event_h as "last event",
                            tracking_mode as "grouped by",
                            first_seen_h as "first seen",
                            last_updated_h as "last updated"
                    </query>
                    </search>
                <option name="drilldown">none</option>
                <option name="count">50</option>
                <option name="wrap">false</option>
                <option name="refresh.display">progressbar</option>
                <format type="color" field="status">
                    <colorPalette type="map">{"✓ Healthy":#53a051,"⚠ Delayed":#f8be34,"✗ Missing data":#dc4e41,"✗ Missing + delayed":#9b1d1d,"🔧 Snoozed":#4ea1f2,"🌙 Off-hours":#6c63ff,"· Just added":#888888,"-":#888888}</colorPalette>
                </format>
            </table>
        </panel>
    </row>

    <row depends="$is_source$ AND $show_empty_s$">
        <panel>
            <html>
                <div class="carbide-empty-state">
                    <h3>No source entities match the current filter</h3>
                    <p>If you've just installed Carbide, run discovery first: <em>Carbide - Discover sources (recommended)</em> from Settings &#8250; Searches.</p>
                </div>
            </html>
        </panel>
    </row>

    <row>
        <panel>
            <title>Advanced: bulk action (single field, free-form value)</title>
            <html>
                <div class="carbide-bulk" id="carbide_bulk_hosts"
                     data-carbide-bulk-target="carbide_tracked_hosts_table"
                     data-carbide-collection="carbide_tracked_hosts"
                     depends="$is_host$">
                    <strong>Bulk (hosts):</strong>
                    <label>field
                        <select class="carbide-bulk-field">
                            <option value="monitored">Watching</option>
                            <option value="max_gap_seconds">Alert if quiet for (sec)</option>
                            <option value="max_latency_seconds">Alert if delayed by (sec)</option>
                            <option value="maintenance_from">Snooze from</option>
                            <option value="maintenance_until">Snooze until</option>
                            <option value="monitoring_schedule">Schedule (247 / weekdays / business_hours)</option>
                            <option value="tags">Tags</option>
                            <option value="tracking_mode">Grouped by</option>
                            <option value="notes">Notes</option>
                        </select>
                    </label>
                    <label>value <input type="text" class="carbide-bulk-value" placeholder="1 / critical / 3600 / +1h" /></label>
                    <button class="btn btn-primary carbide-bulk-apply">Apply to filtered</button>
                    <span class="carbide-bulk-count"></span>
                </div>
                <div class="carbide-bulk" id="carbide_bulk_sources"
                     data-carbide-bulk-target="carbide_tracked_sources_table"
                     data-carbide-collection="carbide_tracked_sources"
                     depends="$is_source$">
                    <strong>Bulk (sources):</strong>
                    <label>field
                        <select class="carbide-bulk-field">
                            <option value="monitored">Watching</option>
                            <option value="max_gap_seconds">Alert if quiet for (sec)</option>
                            <option value="max_latency_seconds">Alert if delayed by (sec)</option>
                            <option value="maintenance_from">Snooze from</option>
                            <option value="maintenance_until">Snooze until</option>
                            <option value="monitoring_schedule">Schedule (247 / weekdays / business_hours)</option>
                            <option value="tags">Tags</option>
                            <option value="tracking_mode">Grouped by</option>
                            <option value="notes">Notes</option>
                        </select>
                    </label>
                    <label>value <input type="text" class="carbide-bulk-value" placeholder="1 / critical / 3600 / +1h" /></label>
                    <button class="btn btn-primary carbide-bulk-apply">Apply to filtered</button>
                    <span class="carbide-bulk-count"></span>
                </div>
            </html>
        </panel>
    </row>

    <row>
        <panel>
            <title>Delete entity</title>
            <html>
                <p style="color:#b8bec5;font-size:13px;">Paste an entity's <code>_key</code> (visible when "Show details" is on) to remove it from Carbide's tracking. Data ingestion is unaffected.</p>
                <div class="carbide-delete-row" depends="$is_host$">
                    <input type="text" id="carbide_delete_key" placeholder="_key to remove"
                           data-carbide-collection="carbide_tracked_hosts"
                           data-carbide-delete-target="carbide_tracked_hosts_table" />
                    <button id="carbide_delete_button" class="btn btn-danger">Delete (host)</button>
                </div>
                <div class="carbide-delete-row" depends="$is_source$">
                    <input type="text" id="carbide_delete_key_sources" placeholder="_key to remove"
                           data-carbide-collection="carbide_tracked_sources"
                           data-carbide-delete-target="carbide_tracked_sources_table" />
                    <button id="carbide_delete_button_sources" class="btn btn-danger">Delete (source)</button>
                </div>
            </html>
        </panel>
    </row>
</form>
