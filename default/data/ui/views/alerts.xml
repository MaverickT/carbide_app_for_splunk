<form version="1.1" theme="dark" stylesheet="carbide.css">
    <label>Alerts</label>
    <description>Recent fires of Carbide alert searches. Configure actions (email, webhook, PagerDuty, ...) on the individual saved searches under Settings &gt; Searches, reports, and alerts.</description>

    <fieldset submitButton="false" autoRun="true">
        <input type="time" token="time_tok" searchWhenChanged="true">
            <label>Time range</label>
            <default>
                <earliest>-7d@h</earliest>
                <latest>now</latest>
            </default>
        </input>
    </fieldset>

    <row>
        <panel>
            <title>Triggered alerts (individual fires)</title>
            <table>
                <!-- Per-fire from the audit log (same source as the rate
                     chart). The /services/alerts/fired_alerts REST endpoint
                     returns one AGGREGATE row per saved search, not per fire,
                     and under different field names - which is why this used
                     to render blank columns. -->
                <search>
                    <query>
                        index=_audit sourcetype=audittrail action="alert_fired" ss_name="Carbide -*"
                        | eval severity = case(severity=1,"informational", severity=2,"low", severity=3,"medium", severity=4,"high", severity&gt;=5,"critical", 1=1, severity)
                        | sort - _time
                        | head 100
                        | table _time, ss_name, severity, sid
                        | rename ss_name as "alert", sid as "search id"
                    </query>
                    <earliest>$time_tok.earliest$</earliest>
                    <latest>$time_tok.latest$</latest>
                </search>
                <option name="drilldown">none</option>
                <option name="count">50</option>
                <format type="color" field="severity">
                    <colorPalette type="map">{"critical":#dc4e41,"high":#f8be34,"medium":#4ea1f2,"low":#888888,"informational":#888888}</colorPalette>
                </format>
            </table>
        </panel>
    </row>

    <row>
        <panel>
            <title>Alert rate (per saved search)</title>
            <chart>
                <search>
                    <query>
                        index=_audit sourcetype=audittrail action="alert_fired" ss_name="Carbide -*"
                        | timechart count by ss_name
                    </query>
                    <earliest>$time_tok.earliest$</earliest>
                    <latest>$time_tok.latest$</latest>
                </search>
                <option name="charting.chart">line</option>
                <option name="charting.legend.placement">bottom</option>
            </chart>
        </panel>
    </row>

    <row>
        <panel>
            <title>Suppression / dedupe summary</title>
            <table>
                <search>
                    <query>
                        | rest /servicesNS/-/carbide_app_for_splunk/saved/searches splunk_server=local
                        | search title="Carbide - Alert:*"
                        | table title alert.suppress alert.suppress.period alert.suppress.fields alert.severity disabled
                        | rename title as "alert", "alert.suppress" as "suppress", "alert.suppress.period" as "period", "alert.suppress.fields" as "by", "alert.severity" as "severity"
                    </query>
                </search>
                <option name="drilldown">none</option>
            </table>
        </panel>
    </row>
</form>
