<form version="1.1" theme="dark" script="carbide_inline_edit.js" stylesheet="carbide.css">
    <label>Entity Filters</label>
    <description>Per-tracking-type include/exclude rules on any of (index, host, source, sourcetype). Use this to keep noisy axes out of monitoring -- e.g. EXCLUDE the per-hour rotating `source` of syslog devices while still tracking the meaningful `source` of Windows event-log forwarders. Wildcards (`*` and `?`) are supported in patterns. Rules apply to discovery AND live status calculation.</description>

    <fieldset submitButton="false" autoRun="true">
        <input type="dropdown" token="filter_type_tok" searchWhenChanged="true">
            <label>Tracking type</label>
            <choice value="*">All</choice>
            <choice value="hosts">hosts</choice>
            <choice value="sources">sources</choice>
            <choice value="both">both</choice>
            <default>*</default>
        </input>
        <input type="dropdown" token="filter_field_tok" searchWhenChanged="true">
            <label>Field</label>
            <choice value="*">All</choice>
            <choice value="index">index</choice>
            <choice value="host">host</choice>
            <choice value="source">source</choice>
            <choice value="sourcetype">sourcetype</choice>
            <default>*</default>
        </input>
    </fieldset>

    <row>
        <panel>
            <html>
                <div class="carbide-toolbar">
                    <div class="carbide-toolbar-info">
                        <strong>Examples</strong> &#8212;
                        exclude noisy syslog source rotation: <code>field=source mode=exclude pattern=/var/log/syslog*</code> for <code>tracking_type=sources</code>.
                        Whitelist windows event-log sourcetypes only for host tracking: <code>field=sourcetype mode=include pattern=wineventlog*</code> for <code>tracking_type=hosts</code>.
                    </div>
                </div>
            </html>
        </panel>
    </row>

    <row>
        <panel>
            <title>Existing filter rules</title>
            <table id="carbide_entity_filters_table"
                   data-carbide-collection="carbide_entity_filters"
                   data-carbide-editable="field_name,pattern,mode,tracking_type,notes"
                   data-carbide-options-field_name="index,host,source,sourcetype"
                   data-carbide-options-mode="include,exclude"
                   data-carbide-options-tracking_type="hosts,sources,both">
                <search>
                    <query>
                        | inputlookup carbide_entity_filters_lookup
                        | search tracking_type="$filter_type_tok$" field_name="$filter_field_tok$"
                        | sort + tracking_type field_name mode pattern
                        | table _key, tracking_type, field_name, mode, pattern, notes
                    </query>
                    </search>
                <option name="drilldown">none</option>
                <option name="count">100</option>
            </table>
        </panel>
    </row>

    <row>
        <panel>
            <title>Add filter rule</title>
            <html>
                <div class="carbide-form">
                    <label>Field
                        <select id="carbide_new_field_name">
                            <option value="index">index</option>
                            <option value="host">host</option>
                            <option value="source">source</option>
                            <option value="sourcetype">sourcetype</option>
                        </select>
                    </label>
                    <label>Pattern <input type="text" id="carbide_new_pattern" placeholder="e.g. wineventlog* or web0?" /></label>
                    <label>Mode
                        <select id="carbide_new_mode">
                            <option value="include">include (whitelist)</option>
                            <option value="exclude">exclude (blacklist)</option>
                        </select>
                    </label>
                    <label>Tracking type
                        <select id="carbide_new_tracking_type">
                            <option value="hosts">hosts</option>
                            <option value="sources">sources</option>
                            <option value="both">both</option>
                        </select>
                    </label>
                    <label>Notes <input type="text" id="carbide_new_notes" placeholder="optional"/></label>
                    <button id="carbide_add_entity_filter"
                            class="btn btn-primary"
                            data-carbide-collection="carbide_entity_filters"
                            data-carbide-target="carbide_entity_filters_table">Add rule</button>
                </div>
            </html>
        </panel>
    </row>

    <row>
        <panel>
            <title>Delete rule</title>
            <html>
                <p>Paste a filter row's <code>_key</code> to remove it.</p>
                <div class="carbide-delete-row">
                    <input type="text" id="carbide_delete_key_filters" placeholder="_key to remove"
                           data-carbide-collection="carbide_entity_filters"
                           data-carbide-delete-target="carbide_entity_filters_table" />
                    <button id="carbide_delete_button_filters" class="btn btn-danger">Delete</button>
                </div>
            </html>
        </panel>
    </row>
</form>
